# ═══════════════════════════════════════════════════
# CampusOne — Environment Variables
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in the values.

# MongoDB Connection String
# Local:   mongodb://localhost:27017/campusone
# Atlas:   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/campusone
MONGO_URI=mongodb://localhost:27017/campusone

# JWT Secret Key (use a long, random string in production)
JWT_SECRET=your_jwt_secret_here

# Server Port
PORT=5000

# Frontend URL (for CORS)
# Local:      http://localhost:3000
# Production: https://your-app.vercel.app
CLIENT_URL=http://localhost:3000
