# ═══════════════════════════════════════════════════════════════
# CampusOne — Production Environment Variables Template
# ═══════════════════════════════════════════════════════════════
# Do NOT commit actual values. Use your hosting platform's
# environment variable settings (Render dashboard, Vercel dashboard).

# ───────────────────────────────────────────────────────────────
# Backend (Render)
# ───────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/campusone
JWT_SECRET=<generate-a-strong-random-secret-here>
PORT=5000
CLIENT_URL=https://your-app.vercel.app

# ───────────────────────────────────────────────────────────────
# Frontend (Vercel) — set these in the Vercel dashboard
# ───────────────────────────────────────────────────────────────
VITE_API_URL=https://your-api.onrender.com/api
