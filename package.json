{
  "name": "campusone",
  "version": "1.0.0",
  "description": "CampusOne — Unified Digital Campus Management Platform",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "seed": "node server/seedERP.js",
    "seed:erp": "node server/seedERP.js",
    "import:problems": "node server/importProblems.js",
    "install-all": "cd server && npm install && cd ../client && npm install",
    "start": "cd server && npm start"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
